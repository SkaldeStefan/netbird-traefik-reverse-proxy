# Required settings
SECRETS_DIR=/etc/docker-secrets/traefik-proxy
ACME_EMAIL=mail@example.com
NETBIRD_BIND_IP=100.64.0.10
BASE_DOMAIN=example.com
TRAEFIK_DASHBOARD_HOST=traefik.example.com

# Docker network used by Traefik and proxied services
TRAEFIK_PROXY_NETWORK=traefik-proxy

# ACME DNS challenge settings
ACME_DNS_PROVIDER=hetzner
ACME_DNS_RESOLVER_1=1.1.1.1:53
ACME_DNS_RESOLVER_2=8.8.8.8:53

# Used in firewall documentation/examples
NETBIRD_INTERFACE=wt0

# Optional image and logging overrides
DOCKER_SOCKET_PROXY_IMAGE=tecnativa/docker-socket-proxy:0.3.0
TRAEFIK_IMAGE=traefik:3.6
DEFAULT_BACKEND_IMAGE=nginx:alpine
TRAEFIK_LOG_LEVEL=INFO

# Token filename inside ${SECRETS_DIR}
HETZNER_TOKEN_FILE_NAME=hetzner_api_token.txt
